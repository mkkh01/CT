# ═══════════════════════════════════════════════════════════
# CT Institutional Trading System — Environment Variables
# ═══════════════════════════════════════════════════════════

# ── Required ───────────────────────────────────────────────

# Telegram Bot Token (from @BotFather)
TELEGRAM_TOKEN=your_telegram_token_here

# ── Optional ───────────────────────────────────────────────

# Binance API Credentials (public endpoints work without them;
# provide for higher rate limits and private endpoints)
# BINANCE_API_KEY=your_binance_api_key_here
# BINANCE_API_SECRET=your_binance_api_secret_here

# PostgreSQL Database URL
RAW_DATABASE_URL=postgresql://user:***@host:port/dbname

# Admin Telegram ID
ADMIN_ID=your_admin_id_here

# Redis Configuration
REDIS_HOST=your_redis_host_here
REDIS_PORT=18244
REDIS_PASSWORD=your_redis_password_here

# Trading Defaults
DEFAULT_CAPITAL=10.0
TRADE_FEE=0.001

# HTF Mode: SKIP | CONTINUE_LOW_CONF | FALLBACK
HTF_MODE=SKIP

# ── Diagnostics ────────────────────────────────────────────

# Set to true/1/yes to enable full internal state logging
DEBUG_MODE=false

# ── Telegram Polling Retry ─────────────────────────────────

# Max retries when polling fails with Conflict (409)
TG_POLLING_MAX_RETRIES=5

# Base backoff in seconds (exponential: base * 2^attempt)
TG_POLLING_BACKOFF_BASE=15

# Maximum backoff cap in seconds
TG_POLLING_BACKOFF_MAX=300

# ── Render Deployment ─────────────────────────────────────

# Render sets PORT automatically; keep_alive.py reads it
# PORT=8080
